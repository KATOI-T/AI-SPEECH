# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Azure Speech Services (推奨)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=japaneast

# AWS Speech Services (代替)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-northeast-1

# AWS S3 Storage (代替)
STORAGE_BACKEND=s3
S3_BUCKET_NAME=your_s3_bucket_name_here

# Google Cloud Speech Services (代替)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Port Configuration
# Frontend: 3000~3200, Backend: 8000~8200
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Database
# DB_HOST: use "db" for local db (make up), "ai_speech-db-1" for external db (make up-no-db)
DB_HOST=db
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ai_speech
MYSQL_USER=user
MYSQL_PASSWORD=password
DATABASE_URL=mysql+pymysql://user:password@db:3306/ai_speech

# Redis
REDIS_PORT=6000
REDIS_URL=redis://redis:6000
